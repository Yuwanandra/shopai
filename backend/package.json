    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "groq-sdk": "^1.1.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "midtrans-client": "^1.3.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
